---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found">
  <main class="sarva-main">
    <p class="sarva-section-label">404</p>
    <h1 style="font-size:2.5rem;font-weight:700;margin-bottom:1rem">Page not found</h1>
    <p style="color:var(--sarva-muted);margin-bottom:2rem;max-width:32rem">
      The page you're looking for doesn't exist or may have been moved.
    </p>
    <a href="/blog" style="color:#4a9eff">← Back to Blog</a>
  </main>
</Base>
